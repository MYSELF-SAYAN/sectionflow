{
  "name": "sectionflow-cli",
  "version": "0.2.6",
  "description": "CLI for installing SectionFlow v2 scroll-driven section transitions (persistent-layer architecture)",
  "keywords": [
    "sectionflow",
    "transitions",
    "react",
    "framer-motion",
    "cli",
    "scroll",
    "animation",
    "next",
    "vite"
  ],
  "homepage": "https://github.com/sectionflow/sectionflow",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sectionflow/sectionflow.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "sectionflow": "dist/index.js",
    "sectionflow-cli": "dist/index.js"
  },
  "files": [
    "dist",
    "transitions",
    "README.md"
  ],
  "scripts": {
    "sync:sources": "node scripts/sync-sources.mjs",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run sync:sources && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
